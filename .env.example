# Public OAuth App Client ID (not a secret). Enables "Connect GitHub" after `npm run build`.
# See docs/github-oauth-app.md
GITHUB_OAUTH_CLIENT_ID=

# Client Secret from the same OAuth App (Settings → Developer settings → OAuth Apps → your app).
# Required for GitHub's classic OAuth authorization-code token exchange; injected into service-worker.js only.
# Never commit real values; anyone with the built extension can read the embedded secret.
# GITHUB_OAUTH_CLIENT_SECRET=

# --- Chrome Web Store Publish API (npm run upload:chrome / publish:chrome only) ---
# Google Cloud OAuth — NOT GitHub. See https://github.com/fregante/chrome-webstore-upload-keys
# CLIENT_ID=
# CLIENT_SECRET=
# REFRESH_TOKEN=
# EXTENSION_ID=
