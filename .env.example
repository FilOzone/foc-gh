# GitHub OAuth — two FilOzone apps (dev unpacked vs prod Store). See extension/README.md.
# Admin links (org permission): dev …/applications/3490509, prod …/3491974
#
# Recommended (.env.local): keep BOTH pairs — no commenting/uncommenting.
#   npm run build        → development profile (embeds …_DEVELOPMENT or plain GITHUB_OAUTH_*)
#   npm run build:zip    → production profile (embeds …_PRODUCTION, or plain if suffixed unset)
#
GITHUB_OAUTH_CLIENT_ID_DEVELOPMENT=
GITHUB_OAUTH_CLIENT_SECRET_DEVELOPMENT=
GITHUB_OAUTH_CLIENT_ID_PRODUCTION=
GITHUB_OAUTH_CLIENT_SECRET_PRODUCTION=

# Shorthand: if you omit …_DEVELOPMENT, `npm run build` falls back to these (same as before).
GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Optional: node scripts/build.mjs reads FOC_GH_OAUTH_PROFILE=development|production if you skip --oauth-profile
# FOC_GH_OAUTH_PROFILE=development

# --- GitHub Actions (optional) ---
# CI `extension-ci.yml` uses plain GITHUB_OAUTH_* for the default development build.
# Publish workflow maps production secrets to GITHUB_OAUTH_* while build:zip uses production profile
# (uses …_PRODUCTION if set, else plain — see scripts/build.mjs).

# --- Chrome Web Store Publish API (npm run upload:chrome / publish:chrome only) ---
# Google Cloud OAuth for the Publish API — NOT GitHub. https://github.com/fregante/chrome-webstore-upload-keys
# chrome-webstore.mjs maps CHROME_WEBSTORE_* → CLI env names (no unprefixed CLIENT_ID in this repo).
CHROME_WEBSTORE_CLIENT_ID=
CHROME_WEBSTORE_CLIENT_SECRET=
CHROME_WEBSTORE_REFRESH_TOKEN=
CHROME_WEBSTORE_EXTENSION_ID=
